{
  "compilerOptions": {
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "outDir": "./dist/",
    "rootDir": "./",
    "sourceMap": true,
    "inlineSourceMap": false,
    "inlineSources": false,
    "removeComments": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "noEmit": false,
    "noEmitHelpers": true,
    "importHelpers": true,
    "noEmitOnError": false,
    "noLib": false,
    "noResolve": false,
    "forceConsistentCasingInFileNames": false,
    "preserveConstEnums": true,
    "isolatedModules": true,
    "allowJs": false,
    "maxNodeModuleJsDepth": 0,
    "checkJs": false,
    "stripInternal": false,
    // "noImplicitUseStrict": false,
    // "suppressExcessPropertyErrors": false,
    // "suppressImplicitAnyIndexErrors": false,
    // "downlevelIteration": false,
    "emitBOM": false,
    // "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "pretty": true,
    "diagnostics": false,
    "listFiles": false,
    "listEmittedFiles": false,
    "traceResolution": false,
    "disableSizeLimit": false,
    "skipLibCheck": true,
    // NODENEXT does not work because of "typed-redux-saga/macro" in WebPack Babel config
    "module": "esnext", // 99
    // "module": "ES2020", // 6
    // "module": "preserve", // 200
    // "module": "nodenext", // 199
    // "moduleResolution": "nodenext", // 99
    // "moduleResolution": "node", // 100
    "moduleResolution": "bundler", // 100
    "lib": ["es2022", "dom"],
    "target": "es2025",
    "jsx": "react",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // "baseUrl": ".",
    "paths": {
      "*": ["./*"],
      // "file-selector": [
      //   "src/typings/noop.d.ts"
      // ],
      "readium-desktop/*": ["./src/*"],
      "test/*": ["./test/*"],
      "@r2-utils-js/*": ["./src/r2-xxx-js/r2-utils-js/*"],
      "@r2-opds-js/*": ["./src/r2-xxx-js/r2-opds-js/*"],
      "@r2-shared-js/*": ["./src/r2-xxx-js/r2-shared-js/*"],
      "@r2-streamer-js/*": ["./src/r2-xxx-js/r2-streamer-js/*"],
      "@r2-navigator-js/*": ["./src/r2-xxx-js/r2-navigator-js/*"],
      "@r2-lcp-js/*": ["./src/r2-xxx-js/r2-lcp-js/*"],
      "@lunr-languages/*": ["./node_modules/lunr-languages/*"],
    },
  },
  "include": ["./src/**/*", "./test/**/*"],
  "exclude": ["./node_modules"],
  "files": ["./typings.d.ts"],
}
